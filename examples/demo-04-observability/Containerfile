ARG UBI_VERSION=9.4

# ════════════════════════════════════════════════════════════════════════
# Build stage — UBI 9.4 with gcc-toolset-14, Conan 2.x for C++ deps.
# ════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi:${UBI_VERSION} AS build

# UBI w/o entitlement: silence subscription-manager.
# Free UBI repos in ubi.repo are unaffected — dnf install works normally.
RUN rm -f /etc/yum.repos.d/redhat.repo && \
    sed -i 's/^enabled=1/enabled=0/' \
        /etc/dnf/plugins/subscription-manager.conf 2>/dev/null || true

# Build basics. Conan handles all C++ ecosystem deps (gRPC, protobuf,
# abseil-cpp, opentelemetry-cpp) — UBI 9 BaseOS+AppStream are enough
# for the toolchain itself. We don't need EPEL for this demo (G-13
# story in the plan covers why we stopped chasing system C++ packages).
#
# The perl-* modules are for openssl's Configure script, which Conan
# runs when building openssl from source. UBI 9 ships a minimal perl;
# the modules each need a separate package. The full list comes from
# openssl/INSTALL.md required-perl-modules — preempting all of them
# saves "add one module, rebuild, hit next" iteration. See G-15/G-16
# in the plan.
RUN dnf install -y --setopt=install_weak_deps=False \
        gcc-toolset-14 \
        cmake \
        ninja-build \
        git \
        python3-pip \
        perl-FindBin \
        perl-IPC-Cmd \
        perl-Data-Dumper \
        perl-Pod-Html \
        perl-Pod-Usage \
        perl-File-Compare \
        perl-File-Copy \
        perl-File-Path \
        perl-Time-Piece \
        perl-Getopt-Long \
        perl-Digest-SHA \
        perl-threads \
        perl-threads-shared \
        perl-Thread-Queue \
        perl-Term-ANSIColor \
    && dnf clean all

ENV PATH=/opt/rh/gcc-toolset-14/root/usr/bin:$PATH

# Conan 2.x via pip — packaged Conan in distros lags upstream and
# Conan 2's CLI/recipe format is what we want.
RUN pip3 install --no-cache-dir 'conan~=2.0'

# Generate a default profile from the running compiler, then pin
# compiler.cppstd to gnu17 for dep builds. Why gnu17 not 23 (G-27):
# our pinned grpc/1.54.3 (G-26) was released mid-2023 against gcc
# 12-13 + cppstd=gnu17 and doesn't compile cleanly against
# gcc 14 + cppstd=23 — the newer compiler+standard rejects code
# patterns the older grpc source still uses. Lowering the *profile*
# cppstd to gnu17 means Conan-managed deps (grpc, protobuf, abseil,
# OTel-cpp) build with gnu17. Our app's CMakeLists.txt separately
# sets CMAKE_CXX_STANDARD 23, which overrides per-target — the
# demo-04-svc binary still compiles with C++23 features. ABI
# compatibility holds because libstdc++'s ABI is stable across
# cppstd versions for the types these libs expose.
RUN conan profile detect --force && \
    sed -i 's|^compiler.cppstd=.*|compiler.cppstd=gnu17|' \
        /root/.conan2/profiles/default

WORKDIR /src

# Vendor cpp-httplib at build time (single header, no Conan recipe
# needed for this version — the project pins its own).
ARG HTTPLIB_VERSION=v0.16.0
RUN mkdir -p src/third_party && \
    curl -fsSL -o src/third_party/httplib.h \
        "https://raw.githubusercontent.com/yhirose/cpp-httplib/${HTTPLIB_VERSION}/httplib.h"

# Conan install: opentelemetry-cpp pulls gRPC, protobuf, abseil, etc.
# from Conan Center as transitive deps. We use conanfile.py (not .txt)
# to override transitive versions when the recipe revision drifts away
# from a documented working combination — see G-25 in the plan.
#
# If conan.lock is non-empty, use it: it pins not just (name, version)
# but (name, version, recipe revision) for every node in the dep
# graph, giving us bit-for-bit reproducible installs against the dep
# graph we shook down across r28-r52. Regenerate via
# scripts/regenerate-demo-04-lockfile.sh when you intentionally want
# to refresh against the latest still-hosted revisions.
#
# If conan.lock is empty (the committed placeholder, used before a
# real lockfile has been generated), fall back to fresh resolution
# with --build=missing. The placeholder approach is more portable
# than glob-based conditional COPY across BuildKit versions.
COPY conanfile.py conan.lock ./
RUN if [ -s conan.lock ]; then \
        echo "==> Using committed conan.lock for reproducible install"; \
        conan install . --output-folder=build/conan \
                        -s build_type=Release \
                        --lockfile=conan.lock \
                        --build=missing ; \
    else \
        echo "==> conan.lock is empty placeholder; resolving graph fresh"; \
        echo "==> Run scripts/regenerate-demo-04-lockfile.sh to lock the graph"; \
        conan install . --output-folder=build/conan \
                        -s build_type=Release \
                        --build=missing ; \
    fi

COPY src/ ./src/
COPY CMakeLists.txt ./

# Build against the Conan-generated toolchain.
RUN cmake -S . -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_TOOLCHAIN_FILE=build/conan/conan_toolchain.cmake \
    && cmake --build build -j"$(nproc)" \
    && strip --strip-all build/demo-04-svc

# ════════════════════════════════════════════════════════════════════════
# Runtime stage — ubi-minimal with just the C++ ABI lib.
# Static linkage from Conan deps means the binary doesn't pull a
# single C++ ecosystem package at runtime.
# ════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi-minimal:${UBI_VERSION}

RUN microdnf install -y --setopt=install_weak_deps=0 \
        libstdc++ \
    && microdnf clean all

ARG GIT_SHA=unknown
LABEL tutorial.demo="04-observability" \
      org.opencontainers.image.revision="${GIT_SHA}"

WORKDIR /app
COPY --from=build /src/build/demo-04-svc /app/demo-04-svc

USER 1001:1001
EXPOSE 8080
ENTRYPOINT ["/app/demo-04-svc"]
