{
  "_comment": "Reference seccomp profile for demo-03 production compose. Generated as: docker/podman default profile + io_uring overlay. Regenerate locally with ./security/build-seccomp-profile.sh against your installed containers-common package — this snapshot is for users without that package or who want to inspect the shape before regenerating. Snapshot represents podman 5.x style default policy approximated; the production setup expects you to use build-seccomp-profile.sh to capture YOUR system's real default + the overlay.",
  "_snapshot_date": "2026-05-10",
  "_snapshot_podman_baseline": "approximated from podman 5.8 default",
  "_regenerate_with": "./security/build-seccomp-profile.sh",

  "defaultAction": "SCMP_ACT_ERRNO",
  "defaultErrnoRet": 1,

  "architectures": [
    "SCMP_ARCH_X86_64",
    "SCMP_ARCH_X86",
    "SCMP_ARCH_X32"
  ],

  "syscalls": [
    {
      "_comment": "io_uring family — OUR OVERLAY. This is what build-seccomp-profile.sh adds on top of the default. Three syscalls only; the kernel's own IORING_OP_* permissions enforce per-op restrictions beyond what seccomp controls.",
      "names": [
        "io_uring_setup",
        "io_uring_enter",
        "io_uring_register"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
