ARG UBI_VERSION=9.4

# ---- libabigail builder stage ----
# We use CentOS Stream 9 for this stage. Reasons:
#   1. libabigail isn't in UBI 9's CRB subset (G-46)
#   2. elfutils-devel isn't in UBI 9's CRB subset (G-47)
#   3. flex + bison aren't in UBI 9's CRB subset either (G-49)
# Cascading source builds for all four became unreasonable. CentOS
# Stream 9 is the Red Hat-maintained development stream that becomes
# RHEL 9 — it has the full CRB enabled (after one `dnf config-manager
# --set-enabled crb`), with libabigail packaged. Same glibc 2.34 as
# UBI 9, so the binaries copy across ABI-compatibly.
#
# This is a deliberate exception to the "UBI everywhere" project
# preference — and a justified one, since CentOS Stream is Red Hat's
# own upstream development stream, not a third-party distribution.
# The runtime image (`svc`, ubi-minimal) is untouched.
FROM quay.io/centos/centos:stream9 AS libabigail-builder
RUN dnf install -y --setopt=install_weak_deps=False \
        dnf-plugins-core \
 && dnf config-manager --set-enabled crb \
 && dnf install -y --setopt=install_weak_deps=False \
        libabigail \
 && dnf clean all \
 && mkdir -p /export/bin /export/lib \
 && cp -av /usr/bin/abidiff /usr/bin/abidw /usr/bin/abilint \
           /usr/bin/abicompat /usr/bin/abipkgdiff /usr/bin/kmidiff \
           /export/bin/ \
 && cp -av /usr/lib64/libabigail*.so* /export/lib/ \
 && cp -av /usr/lib64/libxxhash*.so* /export/lib/ \
 && cp -av /usr/lib64/libbpf*.so* /export/lib/

# ---- toolchain base ----
FROM registry.access.redhat.com/ubi9/ubi:${UBI_VERSION} AS toolchain

# UBI w/o entitlement: silence subscription-manager.
# Free UBI repos in ubi.repo are unaffected — dnf install works normally.
RUN rm -f /etc/yum.repos.d/redhat.repo && \
    sed -i 's/^enabled=1/enabled=0/' \
        /etc/dnf/plugins/subscription-manager.conf 2>/dev/null || true

# Enable EPEL 9 — UBI 9 doesn't ship cppcheck in its core repos.
# (libabigail is provided by the libabigail-builder stage above; we
# don't need EPEL for it.) CRB (CodeReady Builder) is already enabled
# in UBI 9 by default, which is the prerequisite for EPEL packages.
RUN dnf install -y \
        https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm

RUN dnf install -y --setopt=install_weak_deps=False \
        gcc-toolset-14 \
        gcc-toolset-14-libasan-devel \
        gcc-toolset-14-libubsan-devel \
        cmake \
        ninja-build \
        clang-tools-extra \
        cppcheck \
        gdb-gdbserver \
        python3-pip \
        git \
        libxml2 \
        elfutils-libelf \
        elfutils-libs \
    && pip install --no-cache-dir \
        'conan>=2.0,<3.0' \
        'gcovr>=7.0' \
    && dnf clean all

# Copy libabigail tools + shared libs from the Stream 9 builder stage.
# Runtime deps (libxml2, elfutils-libelf, elfutils-libs) come from UBI's
# BaseOS repo — same elfutils 0.190 as Stream 9 ships, so ABI-compatible.
COPY --from=libabigail-builder /export/bin/  /usr/local/bin/
COPY --from=libabigail-builder /export/lib/  /usr/local/lib/

ENV PATH=/opt/rh/gcc-toolset-14/root/usr/bin:/usr/local/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/rh/gcc-toolset-14/root/usr/lib64:/usr/local/lib

# ---- build stage ----
FROM toolchain AS build
WORKDIR /src
COPY conanfile.py CMakeLists.txt CMakePresets.json .clang-tidy ./
COPY src/ ./src/
COPY tests/ ./tests/
COPY conan.lock ./conan.lock

# Hermetic Conan install: reads conan.lock when present, falls back to
# fresh resolution when not (e.g., when host-side regen failed and the
# placeholder lockfile was truncated to zero bytes — see G-44 + G-48
# in demo.sh).
#
# G-50: in the else-branch we explicitly `rm -f conan.lock` BEFORE
# running `conan install`. Conan 2.x auto-discovers any `conan.lock`
# in CWD even without the --lockfile flag, and trying to parse a
# zero-byte file fails with:
#   ERROR: Error parsing lockfile '/src/conan.lock':
#   Expecting value: line 1 column 1 (char 0)
# Removing the empty placeholder before conan install fires lets the
# fresh-resolve path actually run.
RUN conan profile detect --force \
 && if [ -s conan.lock ]; then \
        conan install . \
            --output-folder=build/release-debuginfo \
            --lockfile=conan.lock \
            --build=missing \
            -s build_type=RelWithDebInfo ; \
    else \
        rm -f conan.lock && \
        conan install . \
            --output-folder=build/release-debuginfo \
            --build=missing \
            -s build_type=RelWithDebInfo ; \
    fi \
 && cmake --preset release-debuginfo \
 && cmake --build --preset release-debuginfo -j"$(nproc)"

# ---- analyzer-soft stage ----
# Runs cppcheck + clang-tidy and ALWAYS writes their reports to /src/reports/,
# regardless of findings. This stage NEVER fails — its job is to capture
# evidence, not to gate. The gating decision lives in the `analyzer` stage
# below.
#
# This split makes two things possible:
#   1. ./demo.sh --analyze-only (production)   → builds through `analyzer`,
#      which fails loudly if cppcheck or clang-tidy report ANY issue.
#   2. ./demo.sh --demo-findings (pedagogical) → builds through
#      `analyzer-soft` only, so readers can see what real findings look
#      like without the build failing.
#
# Same pattern as abi-diff vs abi.
FROM build AS analyzer-soft
WORKDIR /src
RUN mkdir -p reports

# cppcheck WITHOUT --error-exitcode so the stage never gates. Findings
# still land in reports/cppcheck.xml; the gating decision is downstream.
RUN cppcheck --enable=warning,style,performance,portability \
        --inline-suppr \
        --xml --xml-version=2 \
        --suppress=missingIncludeSystem \
        -I src/include src/ 2> reports/cppcheck.xml \
  || true

# clang-tidy. .clang-tidy has WarningsAsErrors='*' which would normally
# make run-clang-tidy exit non-zero on any finding. The `|| true` swallows
# that exit; the diagnostics are already captured in reports/clang-tidy.txt
# regardless. The gating happens in the `analyzer` stage.
#
# `-quiet` suppresses clang-tidy's "Enabled checks:" preamble (~280 lines
# listing every check) and progress messages. Diagnostics, code-snippet
# context lines, and summary lines ("N warnings generated", "M warnings
# treated as errors") are NOT affected — those are the signal.
RUN run-clang-tidy -p build/release-debuginfo -j"$(nproc)" -quiet \
        $(find src -name '*.cpp') > reports/clang-tidy.txt 2>&1 \
  || true

# ---- analyzer stage ----
# Inherits the captured reports from analyzer-soft and gates strictly:
#   - cppcheck.xml: any <error ...> tag fails the build
#   - clang-tidy.txt: any line matching "FILE:LINE:COL: warning|error:"
#     (the standard diagnostic format) fails the build
#
# Building this target re-runs the analyzers via cache invalidation only
# when source changes; otherwise the reports are reused from analyzer-soft.
FROM analyzer-soft AS analyzer
WORKDIR /src

# Gate on cppcheck findings.
RUN if grep -q '<error ' reports/cppcheck.xml; then \
        echo "cppcheck reported findings:"; \
        cat reports/cppcheck.xml; \
        exit 1; \
    fi

# Gate on clang-tidy findings. The regex matches the canonical diagnostic
# line shape (path:line:col: severity:) so we don't trip on summary lines
# like "1234 warnings generated" that include the word "warning".
RUN if grep -qE ':[0-9]+:[0-9]+: (warning|error):' reports/clang-tidy.txt; then \
        echo "clang-tidy reported findings:"; \
        cat reports/clang-tidy.txt; \
        exit 1; \
    fi

# ---- test stage ----
FROM build AS tests
WORKDIR /src
# Use absolute path for --output-junit; ctest --preset runs from the
# binaryDir (/src/build/release-debuginfo), so relative paths land there
# rather than at /src/reports where demo.sh's `podman cp /src/reports/`
# looks for them.
RUN mkdir -p /src/reports \
 && ctest --preset release-debuginfo --output-on-failure \
          --output-junit /src/reports/gtest.xml \
  || (echo "test stage failed"; exit 1)

# ---- asan stage ----
# Builds a parallel ASan+UBSan-instrumented variant of the library and tests,
# then runs ctest. Sanitizer findings exit nonzero with a stack trace; ctest
# captures them in reports/asan.txt for CI consumption.
FROM build AS asan
WORKDIR /src
# G-50: rm -f conan.lock in else-branch before conan install — conan
# 2.x auto-discovers conan.lock in CWD even without --lockfile flag,
# and a zero-byte file fails JSON parse. See build stage above.
# Note: the conan.lock from the build stage's CWD is inherited via the
# FROM build base, so it may already be present here even if we're
# re-resolving against different sanitizer settings.
RUN if [ -s conan.lock ]; then \
        conan install . \
            --output-folder=build/asan \
            --lockfile=conan.lock \
            --build=missing \
            -s build_type=Debug \
            -c tools.build:cxxflags=[\"-fsanitize=address,undefined\",\"-fno-omit-frame-pointer\",\"-O1\",\"-g\"] \
            -c tools.build:exelinkflags=[\"-fsanitize=address,undefined\"] \
            -c tools.build:sharedlinkflags=[\"-fsanitize=address,undefined\"] ; \
    else \
        rm -f conan.lock && \
        conan install . \
            --output-folder=build/asan \
            --build=missing \
            -s build_type=Debug \
            -c tools.build:cxxflags=[\"-fsanitize=address,undefined\",\"-fno-omit-frame-pointer\",\"-O1\",\"-g\"] \
            -c tools.build:exelinkflags=[\"-fsanitize=address,undefined\"] \
            -c tools.build:sharedlinkflags=[\"-fsanitize=address,undefined\"] ; \
    fi \
 && cmake --preset asan \
 && cmake --build --preset asan -j"$(nproc)"
ENV ASAN_OPTIONS=halt_on_error=1:detect_leaks=1:print_stacktrace=1:abort_on_error=1
ENV UBSAN_OPTIONS=halt_on_error=1:print_stacktrace=1
RUN mkdir -p /src/reports \
 && ctest --preset asan --output-on-failure --output-junit /src/reports/asan.xml 2>&1 \
        | tee /src/reports/asan.txt \
  || (echo "ASan stage failed; see reports/asan.txt"; exit 1)

# ---- coverage-gcc stage ----
# Builds a parallel coverage-instrumented variant of the library and tests
# (--coverage = -fprofile-arcs -ftest-coverage), runs ctest, then post-
# processes with gcovr to produce reports/coverage-gcc/index.html plus
# several machine-readable formats for CI.
#
# Why gcovr and not lcov?
#   The straightforward choice would have been lcov + genhtml, but the
#   UBI 9 EPEL mirror doesn't ship perl-JSON (lcov 1.14's dependency) —
#   see G-55 in the plan. gcovr is a Python alternative that's
#   pip-installable, doesn't depend on the perl chain, has cleaner
#   gcc-14 compatibility, and produces multiple output formats from a
#   single invocation (HTML for humans, Cobertura XML for CI, JSON for
#   tools, plain text for terminals).
#
# The one cross-version gotcha that still applies:
#   gcovr internally shells out to `gcov` to parse .gcda/.gcno files.
#   That gcov must match the gcc that built the code. UBI 9's
#   /usr/bin/gcov is gcc 11; our compile uses gcc-toolset-14's gcc
#   14.2.1. Pass --gcov-executable to point gcovr at the SCL gcov.
FROM build AS coverage-gcc
WORKDIR /src
RUN if [ -s conan.lock ]; then \
        conan install . \
            --output-folder=build/coverage-gcc \
            --lockfile=conan.lock \
            --build=missing \
            -s build_type=Debug \
            -c tools.build:cxxflags='["--coverage","-O0","-g"]' \
            -c tools.build:exelinkflags='["--coverage"]' \
            -c tools.build:sharedlinkflags='["--coverage"]' ; \
    else \
        rm -f conan.lock && \
        conan install . \
            --output-folder=build/coverage-gcc \
            --build=missing \
            -s build_type=Debug \
            -c tools.build:cxxflags='["--coverage","-O0","-g"]' \
            -c tools.build:exelinkflags='["--coverage"]' \
            -c tools.build:sharedlinkflags='["--coverage"]' ; \
    fi \
 && cmake --preset coverage-gcc \
 && cmake --build --preset coverage-gcc -j"$(nproc)"
RUN mkdir -p /src/reports/coverage-gcc \
 && ctest --preset coverage-gcc --output-on-failure \
          --output-junit /src/reports/coverage-gcc.xml \
 && gcovr --root /src \
          --gcov-executable /opt/rh/gcc-toolset-14/root/usr/bin/gcov \
          --filter 'src/' \
          --exclude '.*/tests/.*' \
          --exclude '/usr/.*' \
          --exclude '/opt/rh/.*' \
          --exclude '.*/\.conan2/.*' \
          --html-details /src/reports/coverage-gcc/index.html \
          --html-title "demo07 coverage (gcov via gcc-toolset-14)" \
          --json /src/reports/coverage.json \
          --cobertura /src/reports/coverage-cobertura.xml \
          --txt /src/reports/coverage-summary.txt \
          --print-summary \
 && echo "Coverage HTML: reports/coverage-gcc/index.html"

# ---- abi-diff stage ----
# Runs abidw + abidiff and ALWAYS captures the diff to reports/abidiff.txt.
# This stage never fails on ABI mismatch — its job is to record the
# evidence. The gating decision lives in the `abi` stage below.
#
# This split makes two things possible:
#   1. ./demo.sh --abi-only (production)        → builds through `abi`,
#      which fails loudly if abidiff finds a break.
#   2. ./demo.sh --abi-break-demo (pedagogical) → builds through
#      `abi-diff`, captures the diff to host, exits cleanly so the
#      audience can SEE what production would have failed on.
FROM build AS abi-diff
WORKDIR /src
COPY abi-reference/ ./abi-reference/
RUN mkdir -p /src/reports \
 && abidw --out-file /src/reports/current.abi \
          build/release-debuginfo/libdemo07_channel.so.1 \
 && if [ -f abi-reference/libdemo07_channel.so.1.abi ]; then \
        abidiff abi-reference/libdemo07_channel.so.1.abi /src/reports/current.abi \
            > /src/reports/abidiff.txt 2>&1 || true; \
    else \
        : > /src/reports/abidiff.txt; \
        echo "No reference yet; current ABI saved at reports/current.abi"; \
    fi

# ---- abi stage ----
# Production gate: fails the build if abidiff captured ANY non-empty
# diff. This is what --abi-only runs in CI.
FROM abi-diff AS abi
RUN if [ -s /src/reports/abidiff.txt ]; then \
        echo "ABI changed:"; \
        cat /src/reports/abidiff.txt; \
        exit 2; \
    fi

# ---- release runtime ----
FROM registry.access.redhat.com/ubi9/ubi-minimal:${UBI_VERSION} AS svc
RUN microdnf install -y --setopt=install_weak_deps=0 libstdc++ \
 && microdnf clean all
COPY --from=build /src/build/release-debuginfo/demo07-svc /app/demo07-svc
COPY --from=build /src/build/release-debuginfo/libdemo07_channel.so* /usr/local/lib/
ENV LD_LIBRARY_PATH=/usr/local/lib
LABEL tutorial.demo="07-quality-pipeline" tutorial.variant="svc"
USER 1001:1001
ENTRYPOINT ["/app/demo07-svc"]

# ---- gdbserver sidecar ----
FROM registry.access.redhat.com/ubi9/ubi:${UBI_VERSION} AS gdbserver

# UBI w/o entitlement: silence subscription-manager.
# Free UBI repos in ubi.repo are unaffected — dnf install works normally.
RUN rm -f /etc/yum.repos.d/redhat.repo && \
    sed -i 's/^enabled=1/enabled=0/' \
        /etc/dnf/plugins/subscription-manager.conf 2>/dev/null || true
RUN dnf install -y --setopt=install_weak_deps=False \
        libstdc++ gdb-gdbserver \
    && dnf clean all
COPY --from=build /src/build/release-debuginfo/demo07-svc /app/demo07-svc
COPY --from=build /src/build/release-debuginfo/libdemo07_channel.so* /usr/local/lib/
ENV LD_LIBRARY_PATH=/usr/local/lib
LABEL tutorial.demo="07-quality-pipeline" tutorial.variant="gdbserver"
EXPOSE 1234
ENTRYPOINT ["gdbserver", "0.0.0.0:1234", "/app/demo07-svc"]
