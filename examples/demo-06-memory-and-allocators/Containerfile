# Demo-06 — memory management & allocator comparison.
#
# Builds THREE variants of the same C++ binary, each compiled with
# different allocator behavior. Compared side-by-side on the
# synthetic JSON-shaped workload via demo.sh:
#
#   demo06-svc-std        std::allocator (default glibc malloc)
#   demo06-svc-pmr        std::pmr (monotonic_buffer + sync_pool_resource)
#   demo06-svc-mimalloc   mimalloc static-linked, replaces global new/delete
#
# Three execution modes:
#
#   Batch (default):  ./demo06-svc-XXX [iters [depth [branch [values]]]]
#                     Runs N iterations, prints JSON stats to stdout.
#                     Used by demo.sh for the comparison table.
#
#   Serve (r81+):     ./demo06-svc-XXX --serve
#                     (or set DEMO06_MODE=serve)
#                     Starts an HTTP server on :8080 with endpoints:
#                       GET /healthz       — liveness
#                       GET /info          — variant + defaults
#                       GET /run?iters=N   — runs workload, returns JSON
#                     Used by compose-serve.yml.
#
#   Observe (r85+):   Same binary, same --serve flag. The serve mode
#                     additionally checks $OTEL_EXPORTER_OTLP_ENDPOINT;
#                     if set, it initializes the OpenTelemetry SDK and
#                     emits a span per /run, a request counter, a
#                     latency histogram, and an INFO log per request.
#                     Used by compose-observe.yml (overlay onto the
#                     LGTM observability stack).
#
# Build cost (r85+):
# - First clean build: 30-60 min (Conan rebuilds opentelemetry-cpp,
#   grpc, protobuf, abseil, openssl from source against gnu17).
# - Subsequent rebuilds (same conanfile): ~30 seconds for our app
#   code. The Conan cache keeps the giant transitive deps.
# - If you only need batch mode and never observe mode, you could
#   delete the opentelemetry-cpp lines from conanfile.py to save
#   that initial wait — but the build cost is one-time.

FROM registry.access.redhat.com/ubi9/ubi:9.5 AS builder

# UBI w/o entitlement: silence the subscription-manager plugin. UBI
# is free and unsubscribed by design; the librhsm warning about
# "0 entitlement certificates" is harmless but noisy on every
# microdnf/dnf invocation. Disabling the plugin removes the noise
# without affecting functionality. Free UBI repos in ubi.repo
# stay enabled and dnf install works normally.
RUN rm -f /etc/yum.repos.d/redhat.repo && \
    sed -i 's/^enabled=1/enabled=0/' \
        /etc/dnf/plugins/subscription-manager.conf 2>/dev/null || true

# Build basics + perl modules required by openssl's Configure script.
# r85 added the perl-* modules: Conan builds openssl from source as
# a transitive dep of opentelemetry-cpp's gRPC exporter; openssl's
# Configure uses these modules at build time. UBI 9 ships a minimal
# perl; each module needs a separate package. The list comes from
# openssl/INSTALL.md required-perl-modules — preempting all of them
# saves "add one module, rebuild, hit next" iteration (the demo-04
# arc that produced G-15/G-16/G-17).
#
# `which` is used by Conan's autotools detection; without it, some
# autoconf-based deps decide they can't find tools and fail
# configure with cryptic messages.
RUN dnf install -y --quiet --setopt=install_weak_deps=False \
        gcc-toolset-14 \
        cmake ninja-build git python3-pip \
        which \
        perl-FindBin \
        perl-IPC-Cmd \
        perl-Data-Dumper \
        perl-Pod-Html \
        perl-Pod-Usage \
        perl-File-Compare \
        perl-File-Copy \
        perl-File-Path \
        perl-Time-Piece \
        perl-Getopt-Long \
        perl-Digest-SHA \
        perl-threads \
        perl-threads-shared \
        perl-Thread-Queue \
        perl-Term-ANSIColor \
    && dnf clean all \
    && rm -rf /var/cache/dnf/*

ENV PATH="/opt/rh/gcc-toolset-14/root/usr/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/rh/gcc-toolset-14/root/usr/lib64"

RUN pip install --quiet "conan~=2.0"

# Profile-detection (G-27 two-layer pattern from demo-04: detect
# gnu17 for dependency C++ builds, override our app to C++23 at
# the CMake-target level).
RUN conan profile detect --force && \
    sed -i 's|^compiler.cppstd=.*|compiler.cppstd=gnu17|' \
        /root/.conan2/profiles/default

WORKDIR /src

# Vendor cpp-httplib at build time (single header, no Conan recipe
# needed for a header-only lib). Same pattern as demo-04. r81 adds
# the optional HTTP-server mode; r82 will wire OTel through it.
ARG HTTPLIB_VERSION=v0.16.0
RUN mkdir -p src/third_party && \
    curl -fsSL -o src/third_party/httplib.h \
        "https://raw.githubusercontent.com/yhirose/cpp-httplib/${HTTPLIB_VERSION}/httplib.h"

COPY conanfile.py conan.lock ./

# r85 adds OTel — the dep graph is now huge (grpc, protobuf, abseil,
# opentelemetry-cpp, openssl, mimalloc) and we want reproducibility.
# Same lockfile pattern as demo-04: if conan.lock is non-empty, use
# it; otherwise resolve fresh.
#
# Why the [ -s conan.lock ] check + rm:
# - The committed conan.lock is intentionally empty in this repo
#   (a placeholder; regenerate via scripts/regenerate-demo-06-lockfile.sh
#   when ready to pin against a specific install snapshot).
# - Conan 2.x auto-detects a `conan.lock` in the working directory
#   and tries to parse it even when --lockfile isn't passed. An
#   empty file fails JSON parsing and aborts the install. So we
#   rm the empty placeholder before falling back to fresh resolve.
# - See G-31 in the gotcha catalog for the full story.
RUN if [ -s conan.lock ]; then \
        echo "==> Using committed conan.lock for reproducible install"; \
        conan install . --output-folder=build/conan \
                        -s build_type=Release \
                        --lockfile=conan.lock \
                        --build=missing ; \
    else \
        echo "==> conan.lock is empty placeholder; resolving graph fresh"; \
        echo "==> Run scripts/regenerate-demo-06-lockfile.sh to pin"; \
        rm -f conan.lock ; \
        conan install . --output-folder=build/conan \
                        -s build_type=Release \
                        --build=missing ; \
    fi

COPY src/         ./src/
COPY CMakeLists.txt ./

RUN cmake -S . -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_TOOLCHAIN_FILE=build/conan/conan_toolchain.cmake \
    && cmake --build build -j"$(nproc)" \
    && strip --strip-all \
        build/demo06-svc-std \
        build/demo06-svc-pmr \
        build/demo06-svc-mimalloc

# ════════════════════════════════════════════════════════════════════════
# Runtime: ubi-minimal with libstdc++ (mimalloc is static-linked).
# All three binaries land in /usr/local/bin so the demo's compose can
# select which to exec.
# ════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.5 AS runtime

# Same UBI-without-entitlement warning suppression as the builder
# stage. ubi-minimal ships microdnf which uses the same plugin
# config path; disabling the plugin here keeps the runtime stage's
# microdnf install output clean.
RUN sed -i 's/^enabled=1/enabled=0/' \
        /etc/dnf/plugins/subscription-manager.conf 2>/dev/null || true

RUN microdnf install -y --setopt=install_weak_deps=0 \
        libstdc++ \
    && microdnf clean all \
    && rm -rf /var/cache/yum

COPY --from=builder /src/build/demo06-svc-std      /usr/local/bin/demo06-svc-std
COPY --from=builder /src/build/demo06-svc-pmr      /usr/local/bin/demo06-svc-pmr
COPY --from=builder /src/build/demo06-svc-mimalloc /usr/local/bin/demo06-svc-mimalloc

# Port 8080 — used by the optional HTTP-server mode (r81+).
# Activate by passing `--serve` argv or setting `DEMO06_MODE=serve`
# in the environment. Default mode (no flag) is batch comparison
# to stdout; the EXPOSE here doesn't force the server mode on.
EXPOSE 8080

# Default entrypoint is a thin wrapper that picks the allocator
# variant from $ALLOC, or runs all three sequentially if unset.
COPY run-all.sh /usr/local/bin/run-all.sh
RUN chmod +x /usr/local/bin/run-all.sh

ENTRYPOINT ["/usr/local/bin/run-all.sh"]
