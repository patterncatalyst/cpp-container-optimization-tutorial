{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release",
      "inherits": "_base",
      "displayName": "Release with thin LTO",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fno-plt"
      }
    },
    {
      "name": "release-static-libstdcxx",
      "inherits": "_base",
      "displayName": "Release with thin LTO + static libstdc++/libgcc",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_EXE_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fno-plt"
      }
    },
    {
      "name": "pgo-generate",
      "inherits": "_base",
      "displayName": "PGO instrumented (-fprofile-generate)",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_RELEASE": "-O2 -DNDEBUG -fprofile-generate",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-generate"
      }
    },
    {
      "name": "pgo-use",
      "inherits": "_base",
      "displayName": "PGO optimized (-fprofile-use)",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fprofile-use=/pgo/default.profdata -Wno-profile-instr-out-of-date -Wno-profile-instr-unprofiled",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-use=/pgo/default.profdata"
      }
    }
  ],
  "buildPresets": [
    { "name": "release",                   "configurePreset": "release" },
    { "name": "release-static-libstdcxx",  "configurePreset": "release-static-libstdcxx" },
    { "name": "pgo-generate",              "configurePreset": "pgo-generate" },
    { "name": "pgo-use",                   "configurePreset": "pgo-use" }
  ]
}
