{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release",
      "inherits": "_base",
      "displayName": "Release with thin LTO",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fno-plt"
      }
    },
    {
      "name": "release-static-pie",
      "inherits": "_base",
      "displayName": "Release with thin LTO + fully static (libc + libstdc++ + libgcc), PIE",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_EXE_LINKER_FLAGS": "-static-pie -static-libgcc -static-libstdc++",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fno-plt -fPIE"
      }
    },
    {
      "name": "pgo-generate",
      "inherits": "_base",
      "binaryDir": "${sourceDir}/build/pgo",
      "displayName": "PGO instrumented (GCC -fprofile-generate)",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_RELEASE": "-O2 -DNDEBUG -fprofile-generate",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-generate"
      }
    },
    {
      "name": "pgo-use",
      "inherits": "_base",
      "binaryDir": "${sourceDir}/build/pgo",
      "displayName": "PGO optimized (GCC -fprofile-use)",
      "cacheVariables": {
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -fprofile-use -fprofile-correction -Wno-coverage-mismatch -Wno-missing-profile",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-use -fprofile-correction"
      }
    }
  ],
  "buildPresets": [
    { "name": "release",                   "configurePreset": "release" },
    { "name": "release-static-pie",        "configurePreset": "release-static-pie" },
    { "name": "pgo-generate",              "configurePreset": "pgo-generate" },
    { "name": "pgo-use",                   "configurePreset": "pgo-use" }
  ]
}
