{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Demo overview",
  "uid": "tutorial-overview",
  "tags": ["tutorial"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(demo_requests_total[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request latency p50/p95/p99 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(demo_request_duration_milliseconds_bucket[1m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(demo_request_duration_milliseconds_bucket[1m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(demo_request_duration_milliseconds_bucket[1m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Service logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{service_name=\"demo-04-svc\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Recent traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "query": "{ resource.service.name=\"demo-04-svc\" }",
          "refId": "A"
        }
      ]
    }
  ]
}
