    },
    {
      "type": "text",
      "version": 1,
      "id": "pmr-label",
      "x": 220,
      "y": 134,
      "width": 460,
      "height": 44,
      "angle": 0,
      "strokeColor": "#1a1a1a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "fontSize": 12,
      "fontFamily": 1,
      "text": "std::pmr resource (often request-scoped)\nmonotonic_buffer_resource → bump-allocate from a hot arena\nunsynchronized_pool_resource → fixed-size object pools",
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "type": "rectangle",
